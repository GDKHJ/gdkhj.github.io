---
const {
  title,
  href,               // ← optional
  tags = [],
  thumb = "",
  summary = "",
} = Astro.props;
---
<article class="card">
  {href ? (
    <a class="thumb-wrap" href={href} aria-label={title}>
      {thumb
        ? <img class="thumb" src={thumb} alt={title} loading="lazy" />
        : <div class="thumb placeholder"><div class="bar" /></div>}
    </a>
  ) : (
    <div class="thumb-wrap">
      {thumb
        ? <img class="thumb" src={thumb} alt={title} loading="lazy" />
        : <div class="thumb placeholder"><div class="bar" /></div>}
    </div>
  )}

  <div class="card-body">
    <h3 class="card-title">
      {href ? <a href={href}>{title}</a> : title}
    </h3>
    {summary && <p class="card-summary">{summary}</p>}
    {tags.length > 0 && (
      <div class="tags">
        {tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    )}
  </div>
</article>
