---
import Hero from "../components/Hero.astro";
// 글로벌 CSS는 프론트매터에서 import하면 자동 번들됨
import "../styles/global.css";

const {
  title = "권혁준 · Portfolio & Notes",
  heroTitle = "권혁준 · Portfolio & Notes",
  heroSub = "Unity · VR · Multiplayer · Backend",
  showHero = true,
} = Astro.props;
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    {showHero && <Hero title={heroTitle} sub={heroSub} />}
    <slot />
  </body>
</html>
