---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const projects = [
  {
    title: "Mimic",
    href: "/project/Mimic",
    tags: ["Unity", "2D", "PC"],
    thumb: "/Image/mimic_thumbnail.png",
    summary: "Unity로 만든 뱀서라이크",
  },
  {
    title: "Rising Hero",
    href: "/project/RisingHero",
    tags: ["Unity", "2D", "Mobile"],
    thumb: "/Image/risinghero_thumbnail.png",
    summary: "달토끼 키우기 클론코딩",
  },
  {
    title: "Vangry Bird",
    href: "/project/VangryBird",
    tags: ["Unity", "VR", "Multiplayer"],
    thumb: "/Image/vangry_thumbnail.png",
    summary: "VR로 플레이하는 Angry Bird",
  },
  {
    title: "Raid",
    href: "/project/Raid",
    tags: ["Unreal Engine", "3D", "PC"],
    thumb: "/Image/Raid_thumbnail.png",
    summary: "UE5로 만든 MORPG 프로토타입",
  },
  {
    title: "Bird",
    href: "/project/Bird",
    tags: ["Unity", "3D", "PC"],
    thumb: "/Image/Bird_thumbnail.jpg",
    summary: "Unity engine으로 개발한 어드벤처 게임",
  },
];

const otherProjects = [
  {
    title: "Sparkle",
    href: "/project/Sparkle",
    tags: ["React", "ChatGPT API", "Web"],
    thumb: "/Image/Sparkle_thumbnail.png",
    summary: "ChatGPT와 연계한 텍스트 게임",
  },
  {
    title: "Bamfly",
    href: "/project/Bamfly",
    tags: ["Unity", "Anamorphic", "Art"],
    thumb: "/Image/Bamfly_thumbnail.png",
    summary: "Unity로 제작한 Anamorphic",
  },
];
---

<BaseLayout
  title="권혁준 Portfolio"
  heroTitle="권혁준 Portfolio"
  heroSub="Unity Game Developer"
  showNav={false}
/>

<main class="container">
  <!-- Introduction -->
  <section id="intro" class="section intro-grid">
    <figure class="profile">
      <img src="/profile.jpg" alt="권혁준 프로필 사진" class="profile-img" />
    </figure>

    <div class="intro-text">
      <h2>Introduction</h2>

      <table class="info-table">
        <tbody>
          <tr>
            <td class="info-label">학력</td>
            <td>제주대학교 컴퓨터공학과 졸업 (2019.03 ~ 2025.03)</td>
          </tr>
          <tr>
            <td class="info-label">자격증</td>
            <td>
              <div class="cert">
                <img src="/Image/Unity_Associate.png" alt="Unity Certified Associate" class="cert-img" />
                <span>Unity Certified Associate: Game Developer</span>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Game Project -->
  <section id="project" class="section">
    <h2>Game Project</h2>
    <div class="grid-cards">
      {projects.map((p) => <ProjectCard {...p} />)}
    </div>
  </section>

  <!-- Other Project -->
  <section id="other-project" class="section">
    <h2>Other Project</h2>
    <div class="grid-cards">
      {otherProjects.map((p) => <ProjectCard {...p} />)}
    </div>
  </section>

<!-- Contact -->
  <section id="contact" class="section">
    <h2>Contact</h2>
    <div class="contact-box">
      <p><a href="mailto:purewise.kwon@gmail.com">purewise.kwon@gmail.com</a></p>
      <p><a href="https://github.com/gdkhj" target="_blank" rel="noopener noreferrer">GitHub</a></p>
    </div>
  </section>
</main>

<style>
  .info-table { width: 100%; border-collapse: collapse; margin-top: 8px; }
  .info-table td { padding: 8px 0; vertical-align: top; line-height: 1.6; }
  .info-table td + td { padding-left: 16px; }
  .info-label { color: var(--muted); font-weight: 600; white-space: nowrap; width: 80px; }
  .info-table a { color: inherit; text-decoration: underline; }

  .cert { display: flex; align-items: center; gap: 10px; }
    .contact-box {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 20px 28px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-left: 4px solid #ffd400;
    border-radius: 12px;
    box-shadow: 0 4px 12px rgba(0,0,0,.04);
    max-width: 320px;
  }
  .contact-box p { margin: 0; line-height: 1.6; }
  .contact-box a { text-decoration: underline; }
</style>