---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const projects = [
  {
    title: "Mimic",
    href: "/project/Mimic",
    tags: ["Unity", "2D", "PC"],
    thumb: "/Image/mimic_thumbnail.png",
    summary: "Unity로 만든 뱀서라이크",
  },
  {
    title: "Rising Hero",
    href: "/project/RisingHero",
    tags: ["Unity", "2D", "Mobile"],
    thumb: "/Image/risinghero_thumbnail.png",
    summary: "달토끼 키우기 클론코딩",
  },
  {
    title: "Vangry Bird",
    href: "/project/VangryBird",
    tags: ["Unity", "VR", "Multiplayer"],
    thumb: "/Image/vangry_thumbnail.png",
    summary: "VR로 플레이하는 Angry Bird",
  },
  {
    title: "Raid",
    href: "/project/Raid",
    tags: ["Unreal Engine", "3D", "PC"],
    thumb: "/Image/Raid_thumbnail.png",
    summary: "UE5로 만든 MORPG 프로토타입",
  },
  {
    title: "Bird",
    href: "/project/Bird",
    tags: ["Unity", "3D", "PC"],
    thumb: "/Image/Bird_thumbnail.jpg",
    summary: "Unity engine으로 개발한 어드벤처 게임",
  },
];

const otherProjects = [
  {
    title: "Sparkle",
    href: "/project/Sparkle",
    tags: ["React", "ChatGPT API", "Web"],
    thumb: "/Image/Sparkle_thumbnail.png",
    summary: "ChatGPT와 연계한 텍스트 게임",
  },
  {
    title: "Bamfly",
    href: "/project/Bamfly",
    tags: ["Unity", "Anamorphic", "Art"],
    thumb: "/Image/Bamfly_thumbnail.png",
    summary: "Unity로 제작한 Anamorphic",
  },
];
---

<BaseLayout
  title="권혁준 · Portfolio & Notes"
  heroTitle="권혁준 · Portfolio & Notes"
  heroSub="Unity · VR · Multiplayer · Backend"
  showNav={false}
/>

<main class="container">
  <!-- Introduction -->
  <section id="intro" class="section intro-grid">
    <figure class="profile">
      <img src="/profile.jpg" alt="권혁준 프로필 사진" class="profile-img" />
    </figure>

    <div class="intro-text">
      <h2>Introduction</h2>
      <p>
        게임 개발을 꿈꾸며 도전을 즐기는 사람입니다.
        새로운 아이디어와 시도를 통해 성장해 나가고자 합니다.
      </p>

      <div class="callout">
        <strong>현재</strong> : 의료 관련 VR 개발중<br />
        <strong>관심</strong> : 클라이언트 개발
      </div>
    </div>
  </section>

  <!-- Game Project -->
  <section id="project" class="section">
    <h2>Game Project</h2>
    <div class="grid-cards">
      {projects.map((p) => <ProjectCard {...p} />)}
    </div>
  </section>

  <!-- Other Project -->
  <section id="other-project" class="section">
    <h2>Other Project</h2>
    <div class="grid-cards">
      {otherProjects.map((p) => <ProjectCard {...p} />)}
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section">
    <h2>Contact</h2>
    <p>
      <a href="mailto:이메일@도메인">이메일</a> ·
      <a href="https://github.com/gdkhj" target="_blank" rel="noopener noreferrer">GitHub</a> ·
      <a href="https://gdkhj.github.io" target="_blank" rel="noopener noreferrer">포트폴리오 메인</a>
    </p>
  </section>
</main>